<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.kmbeast.mapper.ClassroomMapper">

    <insert id="save">
        INSERT INTO classroom (name, cover, detail, status, create_time)
        VALUES (#{name}, #{cover}, #{detail},#{status}, #{createTime})
    </insert>

    <update id="update">
        UPDATE classroom
        <set>
            <if test="name != null and name != ''">
                name = #{name},
            </if>
            <if test="cover != null and cover != ''">
                cover = #{cover},
            </if>
            <if test="detail != null and detail != ''">
                detail = #{detail},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="batchDelete" parameterType="list">
        DELETE FROM classroom WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="query" resultMap="BaseResultMap">

        SELECT c.*
        FROM classroom c
        <where>
            <if test="id != null">
                AND c.id = #{id}
            </if>
            <if test="status != null">
                AND c.status = #{status}
            </if>
            <if test="name != null and name != ''">
                AND c.name LIKE concat('%',#{name},'%')
            </if>
            <if test="startTime != null and endTime != null">
                AND c.create_time BETWEEN #{startTime} AND #{endTime}
            </if>
        </where>
        ORDER BY c.create_time DESC
        <if test="current != null and size != null">
            LIMIT #{current},#{size}
        </if>
    </select>

    <select id="seats" resultType="cn.kmbeast.pojo.vo.ChartVO">

        SELECT c.name, (SELECT COUNT(*) FROM seat_info si WHERE si.classroom_id = c.id)
        FROM classroom c

    </select>

    <select id="queryCount" resultType="integer">

        SELECT COUNT(*)
        FROM classroom c
        <where>
            <if test="status != null">
                AND c.status = #{status}
            </if>
            <if test="name != null and name != ''">
                AND c.name LIKE concat('%',#{name},'%')
            </if>
            <if test="startTime != null and endTime != null">
                AND c.create_time BETWEEN #{startTime} AND #{endTime}
            </if>
        </where>

    </select>

    <resultMap id="BaseResultMap" type="cn.kmbeast.pojo.entity.Classroom">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="cover" property="cover"/>
        <result column="detail" property="detail"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>


</mapper>
